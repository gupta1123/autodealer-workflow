{
  "name": "autodealer-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": "24.x",
    "npm": "11.x"
  },
  "scripts": {
    "dev:web": "npm run dev --workspace @autodealer/web",
    "dev:api": "npm run dev --workspace @autodealer/api",
    "build:web": "npm run build --workspace @autodealer/web",
    "build:api": "npm run build --workspace @autodealer/api",
    "heroku-postbuild": "npm run build:api",
    "build": "npm run build:web && npm run build:api",
    "lint:web": "npm run lint --workspace @autodealer/web",
    "lint:api": "npm run lint --workspace @autodealer/api",
    "lint": "npm run lint:web && npm run lint:api",
    "typecheck:web": "npm run typecheck --workspace @autodealer/web",
    "typecheck:api": "npm run typecheck --workspace @autodealer/api",
    "typecheck": "npm run typecheck:web && npm run typecheck:api",
    "worker": "npm run worker --workspace @autodealer/api",
    "worker:local": "npm run worker:local --workspace @autodealer/api"
  },
  "dependencies": {
    "@google/genai": "^0.5.0",
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.546.0",
    "next": "^15.5.10",
    "pdfjs-dist": "^4.4.168",
    "react": "^19.1.5",
    "react-dom": "^19.1.5",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.5.10",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
